# Glass Box AI — example environment variables.
# Copy to .env (which is gitignored) and fill in real values.
# Do NOT commit the populated .env.

# Azure subscription
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_RESOURCE_GROUP=GlassBoxAI-Hackathon
AZURE_REGION=eastus

# Azure AI Document Intelligence
DOCINTEL_ENDPOINT=
DOCINTEL_KEY=

# Azure AI Search
SEARCH_ENDPOINT=
SEARCH_ADMIN_KEY=
SEARCH_INDEX_NAME=glassbox-policies

# Azure OpenAI
AOAI_ENDPOINT=
AOAI_KEY=
AOAI_DEPLOYMENT=gpt-4-1
AOAI_API_VERSION=2024-10-21

# Azure Blob Storage (policy PDFs)
BLOB_CONNECTION_STRING=
BLOB_CONTAINER=policies

# Azure Communication Services (WhatsApp / SMS)
ACS_CONNECTION_STRING=
ACS_WHATSAPP_FROM=
ACS_SMS_FROM=

# Power Platform environment URL (for reference)
POWER_PLATFORM_ENV_URL=

# Demo / shared mailbox for email channel
CLAIMS_INBOX=claims@example.com
