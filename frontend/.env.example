# Glass Box AI — frontend environment template.
# Copy this file to `.env` (gitignored) and fill in the values, then restart `npm run dev`.
# Vite reads env vars only at server start — restart after any change.

# Published Copilot Studio agent web-chat URL (Sara).
# Get it: Copilot Studio -> Glass Box Claims Assistant -> Publish -> Channels ->
#   "Custom website" -> copy the URL inside the iframe src="..." (NOT the whole <iframe> tag).
# Looks like: https://copilotstudio.microsoft.com/environments/<env-id>/bots/<bot-id>/webchat?...
# Consumed by: src/config.js -> COPILOT_EMBED_URL -> src/customer/Chat.jsx (/customer/chat route).
VITE_COPILOT_EMBED_URL=

# GlassBox-GetClaimAudit read-flow HTTP URL (Day-2: drives Theater Mode from real
# Decision_Rationale rows). Get it from the flow's "When an HTTP request is received" trigger URL.
# Consumed by: src/config.js -> CLAIM_AUDIT_URL.
VITE_CLAIM_AUDIT_URL=

# ---------------------------------------------------------------------------
# Notify server (server/notify.mjs · `npm run notify`) — sends REAL email/Teams
# from the CommsDispatch UI. These are SERVER-side (no VITE_ prefix); loaded via
# Node --env-file. Leave blank to keep a channel as the on-screen visual.
# ---------------------------------------------------------------------------
# Email provider preference: Azure Communication Services first, else Gmail.
# --- Option A: Azure Communication Services (Microsoft-native) ---
#   ACS resource -> Keys -> Connection string. Sender from a linked Email
#   Communication domain (Azure Managed Domain = DoNotReply@<guid>.azurecomm.net).
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS=

# --- Option B: Gmail App Password (needs 2-Step Verification) ---
#   https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
NOTIFY_EMAIL_TO=you@gmail.com

# Real Teams post — Incoming Webhook URL, or Power Automate "when a webhook
# request is received" URL (build the flow to read the `text` property).
TEAMS_WEBHOOK_URL=

# Optional real SMS (Twilio). Blank = SMS stays a visual card.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
SMS_TO=

# Notify server port (must match the vite proxy target in vite.config.js)
NOTIFY_PORT=8787
