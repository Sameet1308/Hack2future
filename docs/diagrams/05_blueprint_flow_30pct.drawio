        <mxCell id="cc_id_lbl" value="Identity&#10;Microsoft Entra ID · SSO + RBAC" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;fontStyle=1;fontColor=#7c2d12" vertex="1" parent="1">
