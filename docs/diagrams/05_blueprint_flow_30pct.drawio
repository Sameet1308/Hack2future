        <mxCell id="cc_obs_icon" value="" style="sketch=0;outlineConnect=0;gradientColor=none;fillColor=none;strokeColor=none;dashed=0;html=1;aspect=fixed;shape=image;image=https://raw.githubusercontent.com/Sameet1308/Hack2future/main/docs/diagrams/icons/azure/Azure_Public_Service_Icons/Icons/management%20%2B%20governance/00012-icon-service-Application-Insights.svg" vertex="1" parent="1">
          <mxGeometry x="34" y="1080" width="36" height="36" as="geometry" />
        </mxCell>
        <mxCell id="cc_obs_lbl" value="Observability&#10;App Insights + Log Analytics · PP DLP" style="text;html=1;align=center;verticalAlign=middle;fontSize=9;fontStyle=1;fontColor=#7c2d12" vertex="1" parent="1">
          <mxGeometry x="76" y="1072" width="220" height="58" as="geometry" />
        </mxCell>

        <mxCell id="cc_comp" value="⚖  Compliance&#10;CO SB21-169 · NAIC · NY DFS · CA AB 2930" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontColor=#5b21b6;fontSize=9;fontStyle=1;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="305" y="1068" width="278" height="64" as="geometry" />
        </mxCell>

        <!-- ======== FOOTER ======== -->
        <mxCell id="ftr" value="30% slot · 600 × 1200 · export PNG at 300% zoom = 1800 × 3600 px = 600 DPI on a 3 × 6 in slot" style="text;html=1;align=center;verticalAlign=middle;fontSize=8;fontStyle=2;fontColor=#94a3b8" vertex="1" parent="1">
          <mxGeometry x="10" y="1145" width="580" height="20" as="geometry" />
        </mxCell>

        <!-- ====================================================
             EDGES (runtime flow + audit + loop-back)
             ==================================================== -->
        <!-- Customer to each channel -->
        <mxCell id="e1" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="user" target="ch_mobile"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="user" target="ch_web"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="user" target="ch_teams"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="user" target="ch_sms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="user" target="ch_email"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Channels to Frontend -->
        <mxCell id="e6" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="ch_mobile" target="swa"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="ch_web" target="swa"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="ch_teams" target="directline"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="ch_sms" target="directline"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="ch_email" target="directline"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Frontend to Intake -->
        <mxCell id="e11" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="swa" target="copilot"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="func" target="copilot"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.0;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="directline" target="copilot"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Intake → Create_Claim -->
        <mxCell id="e14" value="calls" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;fontColor=#dc2626;fontSize=8;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="copilot" target="create_claim"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Create_Claim → Master (via Dataverse trigger) -->
        <mxCell id="e15" value="Dataverse trigger" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;dashed=1;fontColor=#dc2626;fontSize=8;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="create_claim" target="pa_master"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Master → 3 parallel agents (fan-out) -->
        <mxCell id="e16" value="fan-out" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;fontColor=#dc2626;fontSize=8;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="pa_master" target="agent_extract_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="pa_master" target="agent_policy_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="pa_master" target="agent_validation_box"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 3 agents → Adjudication (join) -->
        <mxCell id="e19" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="agent_extract_box" target="agent_adjud_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e20" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="agent_policy_box" target="agent_adjud_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e21" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="agent_validation_box" target="agent_adjud_box"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Adjudication → Tier 1/2/3 -->
        <mxCell id="e22" value="≥ 0.85" style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=1.5;fontColor=#16a34a;fontSize=8;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="agent_adjud_box" target="tier1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" value="0.60-0.85" style="endArrow=classic;html=1;strokeColor=#d97706;strokeWidth=1.5;fontColor=#d97706;fontSize=8;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="agent_adjud_box" target="tier2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e24" value="&lt; 0.60" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;fontColor=#dc2626;fontSize=8;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="agent_adjud_box" target="tier3"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Tier 2 → Adjuster Card  ·  Tier 3 → CSR Chat -->
        <mxCell id="e25" style="endArrow=classic;html=1;strokeColor=#d97706;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="tier2" target="adjuster_card"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e26" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="tier3" target="csr_chat"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Tier 1 → Explanation (skips human)  ·  Adjuster → Explanation  ·  CSR → Explanation -->
        <mxCell id="e27" style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="tier1" target="explanation_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e28" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="adjuster_card" target="explanation_box"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e29" style="endArrow=classic;html=1;strokeColor=#5a6680;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="csr_chat" target="explanation_box"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Explanation → Notify -->
        <mxCell id="e30" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="explanation_box" target="pa_notify_box"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Notify → Customer (LOOP BACK, dashed) -->
        <mxCell id="e31" value="answer on customer's channel" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=1.5;dashed=1;fontColor=#dc2626;fontSize=8;fontStyle=2;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="pa_notify_box" target="user"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- AUDIT arrows (gold dashed) - Explanation READS, others WRITE -->
        <mxCell id="a_intake" value="audit" style="endArrow=classic;html=1;strokeColor=#d99416;strokeWidth=1.0;dashed=1;fontColor=#a16207;fontSize=7;fontStyle=2;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="copilot" target="audit_chip"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_adjud" style="endArrow=classic;html=1;strokeColor=#d99416;strokeWidth=1.0;dashed=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="agent_adjud_box" target="audit_chip"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a_expl_read" value="reads" style="endArrow=classic;html=1;strokeColor=#d99416;strokeWidth=1.0;dashed=1;startArrow=classic;fontColor=#a16207;fontSize=7;fontStyle=2;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="explanation_box" target="audit_chip"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
