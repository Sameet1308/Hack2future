        <!-- ============================================================ -->
        <!-- NUMBERED FLOW ARROWS — happy path (red) -->
        <!-- ============================================================ -->
        <!-- (1) Customer → Mobile App channel -->
        <mxCell id="f1" value="(1) files FNOL" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="customer" target="ch_mobile">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (2) Channel → Static Web Apps customer surface -->
        <mxCell id="f2" value="(2) channel → SPA" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="ch_mobile" target="fe_swa_cust">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (3) SPA → Bot Service via Token Broker (token first) -->
        <mxCell id="f3" value="(3) Direct Line token" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="fe_swa_cust" target="fe_func_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (4) Frontend → Intake Agent via Direct Line WebSocket -->
        <mxCell id="f4" value="(4) WebSocket → Intake Agent" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3" edge="1" parent="1" source="fe_bot_card" target="cs_intake_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (5) Intake → Create_Claim -->
        <mxCell id="f5" value="(5) call  Create_Claim" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5" edge="1" parent="1" source="cs_intake_card" target="pa_create_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (6) Create → Master (Dataverse trigger) -->
        <mxCell id="f6" value="(6) Dataverse trigger" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="pa_create_card" target="pa_master_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (7) Master → Agents (fan-out arrows, 4 of them) -->
        <mxCell id="f7a" value="(7) fan-out  →  parallel" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5" edge="1" parent="1" source="pa_master_card" target="ag_ext_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f7b" value="" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="pa_master_card" target="ag_pol_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="f7c" value="" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5" edge="1" parent="1" source="pa_master_card" target="ag_val_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (8) Join into Adjudication -->
        <mxCell id="f8a" value="(8) join → Adjudication" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="ag_val_card" target="ag_adj_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (9) Adjudication → Tier Router -->
        <mxCell id="f9" value="(9) decision → router" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="ag_adj_card" target="dec_router">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (10a) Router → Tier 1 (happy path) — red -->
        <mxCell id="f10" value="(10) Tier-1 auto-approve" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="dec_router" target="dec_t1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (10b) Router → Tier 2 (Teams) — black -->
        <mxCell id="f10b" value="" style="endArrow=classic;html=1;strokeColor=#0f172a;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="dec_router" target="dec_t2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (10c) Router → Tier 3 (CSR) — black -->
        <mxCell id="f10c" value="" style="endArrow=classic;html=1;strokeColor=#0f172a;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="dec_router" target="dec_t3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (11) Tier 1 → Notify_Customer -->
        <mxCell id="f11" value="(11) notify customer" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="dec_t3" target="dec_notify_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (12) Notify → Explanation Agent picks up audit and replies -->
        <mxCell id="f12" value="(12) Explanation Agent reads audit → replies on original channel" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5" edge="1" parent="1" source="dec_notify_card" target="cs_expl_card">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (13) Explanation Agent → Customer's channel column -->
        <mxCell id="f13" value="(13) explanation reaches customer" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5" edge="1" parent="1" source="cs_expl_card" target="ch_email">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- AUDIT ARROWS (gold dashed) — each agent → Decision_Rationale -->
        <!-- ============================================================ -->
