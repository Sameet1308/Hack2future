        <mxCell id="pa_master" value="Master_Orchestration  flow&#10;&#10;Trigger: Claim row added (Dataverse)&#10;&#10;① Fan-out → Extraction · Policy · Validation (parallel)&#10;② Join → call Adjudication&#10;③ Route by tier → Notify_Customer + Explanation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede4f5;strokeColor=#742774;strokeWidth=2;fontColor=#3d2c70;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="478" width="380" height="200" as="geometry" />
