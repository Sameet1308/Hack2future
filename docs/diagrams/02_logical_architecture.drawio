        <mxCell id="i5" value="&lt;font style=&quot;font-size:18px;color:#742774&quot;&gt;&lt;b&gt;5&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;CREATE_CLAIM FLOW&lt;br&gt;Power Automate inserts Claim + Document rows in Dataverse." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#e9d5ff;fontColor=#3d2c70;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
          <mxGeometry x="1395" y="380" width="490" height="48" as="geometry" />
        </mxCell>
        <mxCell id="i6" value="&lt;font style=&quot;font-size:18px;color:#742774&quot;&gt;&lt;b&gt;6&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;MASTER_ORCHESTRATION&lt;br&gt;Triggered by Claim row insert. Fans out to 7 · 8 · 9 in parallel." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#e9d5ff;fontColor=#3d2c70;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
