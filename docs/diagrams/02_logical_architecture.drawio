        <mxCell id="flow2" value="(2) Direct Line WebSocket" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="swa_customer" target="bot_icon">
