        <mxCell id="i1" value="&lt;font style=&quot;font-size:18px;color:#9a3412&quot;&gt;&lt;b&gt;1&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;CUSTOMER FILES FNOL&lt;br&gt;Mobile App · Web Chat · Teams · SMS · Email. Channel context carried forward." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#fed7aa;fontColor=#9a3412;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
