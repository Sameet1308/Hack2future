        <mxCell id="flow4" value="(4) Call Create_Claim" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="cs_icon_intake" target="pa_icon_create">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow5" value="(5) Insert Claim row → trigger Master" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="pa_icon_create" target="pa_icon_master">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow6" value="(6) Parallel Extraction + Policy + Validation" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="pa_icon_master" target="L5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow7" value="(7) Every step → audit log" style="endArrow=classic;html=1;strokeColor=#f5b73a;strokeWidth=2.5;dashed=1;fontColor=#a16207;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=1;entryY=0" edge="1" parent="1" source="L5" target="dv_audit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow8" value="(8) Adjudication → Notify_Customer" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5" edge="1" parent="1" source="ai_aoai" target="pa_icon_notify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="flow9" value="(9) Explanation Agent reads audit, replies on original channel" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=1;exitY=0;entryX=0;entryY=1" edge="1" parent="1" source="dv_audit" target="cs_icon_explanation">
