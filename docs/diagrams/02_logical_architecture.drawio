        <mxCell id="cs_intake" value="Intake Agent  (AI)&#10;Parent topic FNOL_Start  ·  11 child topics (one per loss type)&#10;3 reusable sub-flows: Identity · Vehicle · Documents&#10;Sentiment check → escalate Tier 3 if distressed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede4f5;strokeColor=#742774;strokeWidth=2;fontColor=#3d2c70;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
          <mxGeometry x="40" y="338" width="700" height="100" as="geometry" />
        </mxCell>
        <mxCell id="cs_expl" value="Explanation Agent  (AI — NOT a human CSR)&#10;Runs after EVERY decision (Tier 1, 2, or 3).&#10;Reads Decision_Rationale → Azure OpenAI summarises in plain English&#10;→ sent back to customer on their original channel via Notify_Customer." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede4f5;strokeColor=#742774;strokeWidth=2;fontColor=#3d2c70;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
