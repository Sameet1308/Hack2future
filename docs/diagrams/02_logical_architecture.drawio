        <mxCell id="dec_notify" value="Notify_Customer  flow  (Power Automate)&#10;&#10;Sends decision on the customer's original channel:&#10;• ACS for SMS · Outlook for email · Push for mobile · Teams chat for Teams users&#10;&#10;Explanation Agent's rationale text is appended to every message." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#107c10;strokeWidth=2;fontColor=#0e3a0e;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10" vertex="1" parent="1">
