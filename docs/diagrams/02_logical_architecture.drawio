        <mxCell id="i12" value="&lt;font style=&quot;font-size:18px;color:#742774&quot;&gt;&lt;b&gt;12&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;EXPLANATION AGENT  (AI — NOT a CSR)&lt;br&gt;Runs on EVERY claim. Reads Decision_Rationale → Azure OpenAI summarises in plain English → returned via 13." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#e9d5ff;fontColor=#3d2c70;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
