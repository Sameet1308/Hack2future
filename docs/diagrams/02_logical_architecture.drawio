        <!-- ============ NUMBERED FLOW (red dashed) — Tier 1 happy path ============ -->
        <!-- 1: customer enters via channel -->
        <mxCell id="flow1" style="endArrow=classic;html=1;startArrow=oval;startFill=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="ch_mobile" target="swa_customer">
          <mxGeometry relative="1" as="geometry" />
          <mxCell id="flow1_lbl" value="(1) Customer files via Mobile App" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];fontColor=#dc2626;fontSize=11;fontStyle=1" vertex="1" connectable="0" parent="flow1">
            <mxGeometry x="-0.5" y="0" relative="1" as="geometry">
              <mxPoint as="offset" />
            </mxGeometry>
          </mxCell>
        </mxCell>

        <!-- 2: SWA Customer → Direct Line -->
        <mxCell id="flow2" value="(2) Direct Line WebSocket" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="swa_customer" target="directline">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 3: Direct Line → Copilot Studio Intake -->
        <mxCell id="flow3" value="(3) → Intake Agent" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="directline" target="cs_intake">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4: Intake → Create Claim flow -->
        <mxCell id="flow4" value="(4) Call Create_Claim flow" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="cs_intake" target="pa_create">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 5: Create Claim → Dataverse Claim -->
        <mxCell id="flow5" value="(5) Insert Claim row" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="pa_create" target="dv_claim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 6: Dataverse trigger → Master Orchestration -->
        <mxCell id="flow6" value="(6) Trigger" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="dv_claim" target="pa_master">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 7: Master → parallel agents -->
        <mxCell id="flow7" value="(7) Parallel · Extraction + Policy + Validation" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="pa_master" target="L5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 8: Adapters write to Glass Box (this happens THROUGHOUT - represented once) -->
        <mxCell id="flow8" value="(8) Every step → Glass Box" style="endArrow=classic;html=1;strokeColor=#f5b73a;strokeWidth=2;dashed=1;fontColor=#a16207;fontSize=10;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="L5" target="dv_glassbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 9: Adjudication output → Tier 2 Teams Card OR Tier 1 settlement -->
        <mxCell id="flow9" value="(9) Tier 2 → Adaptive Card" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=10;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="ai_aoai" target="m_teamscard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 10: notification back to customer -->
        <mxCell id="flow10" value="(10) Notify customer · Explanation Agent on original channel" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2;dashed=1;fontColor=#dc2626;fontSize=10;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1" edge="1" parent="1" source="dv_glassbox" target="cs_explanation">
          <mxGeometry relative="1" as="geometry" />
