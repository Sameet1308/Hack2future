        <mxCell id="dec_t1" value="Tier 1  ·  Auto-Approve  (AI only — no human)&#10;Confidence ≥ 0.85 → pay claim immediately" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#14532d;fontSize=11;fontStyle=1" vertex="1" parent="1">
