        <mxCell id="i3" value="&lt;font style=&quot;font-size:18px;color:#0078d4&quot;&gt;&lt;b&gt;3&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;DIRECT LINE BRIDGE&lt;br&gt;Bot Service opens a WebSocket between SPA and Copilot Studio." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#bfdbfe;fontColor=#0a2540;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
          <mxGeometry x="1395" y="255" width="490" height="50" as="geometry" />
        </mxCell>
        <mxCell id="i4" value="&lt;font style=&quot;font-size:18px;color:#742774&quot;&gt;&lt;b&gt;4&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;INTAKE AGENT  (AI · Copilot Studio)&lt;br&gt;Parent topic FNOL_Start routes to 1 of 11 loss-type child topics. 3 sub-flows (Identity / Vehicle / Documents). Sentiment check." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#faf5ff;strokeColor=#e9d5ff;fontColor=#3d2c70;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
