        <mxCell id="i11" value="&lt;font style=&quot;font-size:18px;color:#107c10&quot;&gt;&lt;b&gt;11&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;TIER ROUTER&lt;br&gt;T1 auto-approve  ·  T2 → Teams Adaptive Card to back-office adjuster  ·  T3 → live CSR via Teams chat." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0fdf4;strokeColor=#bbf7d0;fontColor=#0e3a0e;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
