        <mxCell id="i2" value="&lt;font style=&quot;font-size:18px;color:#0078d4&quot;&gt;&lt;b&gt;2&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;REACT SPA + TOKEN BROKER&lt;br&gt;Azure Static Web Apps. Customer surface /customer/*. Token Broker (Function) mints Direct Line token — secret stays server-side." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#bfdbfe;fontColor=#0a2540;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
