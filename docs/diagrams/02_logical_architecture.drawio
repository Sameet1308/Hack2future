          <mxGeometry x="450" y="478" width="240" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ag_pol" value="Policy Agent&#10;&#10;Azure AI Search&#10;Vector RAG over policy PDFs&#10;&#10;Returns coverage + clauses + citations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#0078d4;strokeWidth=2;fontColor=#0a2540;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=10;spacingTop=10" vertex="1" parent="1">
