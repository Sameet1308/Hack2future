        <!-- ===== NUMBERED FLOW ARROWS (Tier-1 happy path) ===== -->
        <mxCell id="flow1" value="(1) Customer files via channel" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="ch_mobile" target="swa_customer">
