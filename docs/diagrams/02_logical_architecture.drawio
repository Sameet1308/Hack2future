        <mxCell id="i7" value="&lt;font style=&quot;font-size:18px;color:#0078d4&quot;&gt;&lt;b&gt;7&lt;/b&gt;&lt;/font&gt;&amp;nbsp;&amp;nbsp;EXTRACTION AGENT  (AI)&lt;br&gt;Doc Intelligence + GPT-4o Vision — parses photos, police reports, towing receipts." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#bfdbfe;fontColor=#0a2540;fontSize=11;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10" vertex="1" parent="1">
