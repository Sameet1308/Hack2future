        <mxCell id="sec_finops" value="Cost projection (per env, per month)&lt;br/&gt;&lt;font style=&quot;font-size:9px&quot;&gt;DEV ≈ $50 · TEST ≈ $200 · PROD scales with claim volume&lt;br/&gt;Largest line items: AOAI tokens, Doc Intelligence pages, Power Platform per-user&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#9a3412;fontSize=9" vertex="1" parent="1">
