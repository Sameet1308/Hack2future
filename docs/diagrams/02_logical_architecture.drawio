        <mxCell id="flow3" value="(3) → Intake Agent" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2.5;dashed=1;fontColor=#dc2626;fontSize=11;fontStyle=1;edgeStyle=orthogonalEdgeStyle;rounded=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0" edge="1" parent="1" source="bot_icon" target="cs_icon_intake">
